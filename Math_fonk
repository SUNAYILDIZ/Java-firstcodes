public class JavaApplication26 {

    /**
     * @param args the command line arguments
     */
    public static void main(String[] args) {
      Scanner input=new Scanner(System.in);
      System.out.print("Please enter a number: ");
      int x =input.nextInt();
      int faktoriyel = 1,faktoriyel1=1,faktoriyel2=1;
        for (int i = 1; i <= 3; i++) {
            faktoriyel *= i;
        }
        for(int i =1;i<=5;i++){
           faktoriyel1 *=i;
        }
        for(int i =1;i<=7;i++){
            faktoriyel2*=i;
        }
        double fonksiyon=(x-Math.pow(x,3)/faktoriyel+Math.pow(x, 5)/faktoriyel1-Math.pow(x, 7)/faktoriyel2);
        System.out.println(fonksiyon);
    }
    
}
