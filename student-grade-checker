package uygulama1;

import java.util.Scanner;

/**
 * GPA Status Checker
 * Bu program kullanıcının girdiği not ortalamasına göre 
 * akademik başarı durumunu ekrana yazdırır.
 * * @author suna1
 */
public class Uygulama1 {

    public static void main(String[] args) {
        // Kullanıcıdan veri almak için Scanner nesnesi oluşturulur
        Scanner input = new Scanner(System.in);
        
        System.out.print("Please enter your GPA (0.0 - 4.0): ");
        
        // Kullanıcının sayısal olmayan bir değer girmesine karşı hata kontrolü eklenebilir
        // Ancak temel mantıkta float değer okunur
        if (input.hasNextFloat()) {
            float gpa = input.nextFloat();

            // Koşul yapıları (if-else if-else)
            if ((gpa > 4.0) || (gpa < 0.0)) {
                System.out.println("INCORRECT GPA: Please enter a value between 0.0 and 4.0");
            } else if (gpa >= 3.5) {
                System.out.println("HIGH HONOUR STUDENT");
            } else if (gpa >= 3.0) {
                System.out.println("You have entered the honor roll");
            } else if (gpa >= 2.5) {
                System.out.println("Not bad but could be better");
            } else if (gpa >= 2.0) {
                System.out.println("You must make an effort");
            } else if (gpa >= 1.0) {
                System.out.println("Pay attention because you may fail the class");
            } else {
                System.out.println("It's time to come to your senses, even past time");
            }
        } else {
            System.out.println("Error: Please enter a valid numeric value.");
        }
        
        // Kaynak sızıntısını önlemek için scanner kapatılır
        input.close();
    }
}
